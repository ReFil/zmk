/dts-v1/;
#include <st/f3/stm32f303Xc.dtsi>

/ {
	model = "ROTR";
	compatible = "rotr", "st,stm32f303";

	chosen {
		zephyr,code-partition = &code_partition;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zmk,kscan = &kscan0;
		zmk,underglow = &led_strip;
	};

	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		label = "KSCAN";
		row-gpios
			= <&gpiob 11 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
		;
		col-gpios
			= <&gpiob 5 GPIO_ACTIVE_HIGH>
			, <&gpiob 4 GPIO_ACTIVE_HIGH>
			, <&gpiob 3  GPIO_ACTIVE_HIGH>
		;
	};
	/*sensors {
		 compatible = "zmk,keymap-sensors";
		 sensors = <&encoder0>;
	};*/
};

&usb {
	status = "okay";
};

&rtc {
	status = "okay";
};

&flash0 {
	/*
	 * For more information, see:
	 * http://docs.zephyrproject.org/latest/guides/dts/index.html#flash-partitions
	 */
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;
		boot_partition: partition@0 {
			label = "adafruit_boot";
			reg = <0x00000000 0x00004000>;
		};
		code_partition: partition@4000 {
			label = "code_partition";
			reg = <0x00004000 0x0003a800>;
		};

		/* Set 6Kb of storage at the end of the 256Kb of flash */
		storage_partition: partition@3e800 {
			label = "storage";
			reg = <0x0003e800 0x00001800>;
		};
	};
};

/*
	&spi1 {
	encoder0 : encoder {
		compatible = "magalpha,ma730";
		label = "KNOB";

		reg = <0>;
    spi-max-frequency = <25000000>;


		resolution = <8>; //degrees per keypress
	};
	cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
};
*/

&spi2 {

  led_strip: ws2812@0 {
    compatible = "worldsemi,ws2812-spi";
    label = "WS2812";

    /* SPI */
    reg = <0>;
    spi-max-frequency = <5250000>;

    /* WS2812 */
    chain-length = <3>; /* number of LEDs */
    spi-one-frame = <0x70>;
    spi-zero-frame = <0x40>;
  };
};
